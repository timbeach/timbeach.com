{
  "voice": "bm_lewis",
  "duration": 307.883,
  "paragraphs": [
    {
      "idx": 0,
      "start": 0.0,
      "end": 9.386666666666667,
      "text": "This site uses a custom, lightweight article system that makes it easy to add new content without any complex build processes or databases."
    },
    {
      "idx": 1,
      "start": 9.386666666666667,
      "end": 11.776,
      "text": "Use This System for Your Own Site"
    },
    {
      "idx": 2,
      "start": 11.776,
      "end": 31.573333333333334,
      "text": "Want to build your own website with this article system? The complete source code is available on GitHub at https://github.com/timbeach/timbeach.com. You can fork the repository and customize it for your own content while keeping the parsimonious design philosophy intact."
    },
    {
      "idx": 3,
      "start": 31.573333333333334,
      "end": 32.59733333333333,
      "text": "How It Works"
    },
    {
      "idx": 4,
      "start": 32.59733333333333,
      "end": 35.498666666666665,
      "text": "The system consists of two simple components:"
    },
    {
      "idx": 5,
      "start": 35.498666666666665,
      "end": 38.63466666666667,
      "text": "Markdown files - Your actual article content"
    },
    {
      "idx": 6,
      "start": 38.63466666666667,
      "end": 43.370666666666665,
      "text": "JSON metadata - Article information like title, date, and tags"
    },
    {
      "idx": 7,
      "start": 43.370666666666665,
      "end": 44.906666666666666,
      "text": "Adding a New Article"
    },
    {
      "idx": 8,
      "start": 44.906666666666666,
      "end": 47.296,
      "text": "Step 1: Create the Markdown File"
    },
    {
      "idx": 9,
      "start": 47.296,
      "end": 51.285333333333334,
      "text": "Create a new markdown file in the articles/ directory:"
    },
    {
      "idx": 10,
      "start": 51.285333333333334,
      "end": 55.38133333333333,
      "text": "Write your article content using standard markdown syntax:"
    },
    {
      "idx": 11,
      "start": 55.38133333333333,
      "end": 56.192,
      "text": "Features"
    },
    {
      "idx": 12,
      "start": 56.192,
      "end": 58.048,
      "text": "Code blocks work perfectly"
    },
    {
      "idx": 13,
      "start": 58.048,
      "end": 59.669333333333334,
      "text": "Bold and italic text"
    },
    {
      "idx": 14,
      "start": 59.669333333333334,
      "end": 61.269333333333336,
      "text": "Links to external sites"
    },
    {
      "idx": 15,
      "start": 61.269333333333336,
      "end": 62.464,
      "text": "Code Example"
    },
    {
      "idx": 16,
      "start": 62.464,
      "end": 65.62133333333334,
      "text": "The system supports all standard markdown features!"
    },
    {
      "idx": 17,
      "start": 65.62133333333334,
      "end": 68.24533333333333,
      "text": "Step 2: Add Metadata to JSON"
    },
    {
      "idx": 18,
      "start": 68.24533333333333,
      "end": 71.78666666666666,
      "text": "Add an entry to articles/articles.json:"
    },
    {
      "idx": 19,
      "start": 71.78666666666666,
      "end": 73.344,
      "text": "Step 3: That's It!"
    },
    {
      "idx": 20,
      "start": 73.344,
      "end": 82.34666666666666,
      "text": "The article will automatically appear in the articles list. No build process, no database, no complex CMS - just files and JSON."
    },
    {
      "idx": 21,
      "start": 82.34666666666666,
      "end": 83.60533333333333,
      "text": "System Features"
    },
    {
      "idx": 22,
      "start": 83.60533333333333,
      "end": 84.97066666666667,
      "text": "Automatic Loading"
    },
    {
      "idx": 23,
      "start": 84.97066666666667,
      "end": 88.192,
      "text": "Articles load from markdown files when available"
    },
    {
      "idx": 24,
      "start": 88.192,
      "end": 91.92533333333333,
      "text": "Falls back to built-in content if files aren't accessible"
    },
    {
      "idx": 25,
      "start": 91.92533333333333,
      "end": 94.50666666666666,
      "text": "No server-side processing required"
    },
    {
      "idx": 26,
      "start": 94.50666666666666,
      "end": 95.82933333333334,
      "text": "Markdown Support"
    },
    {
      "idx": 27,
      "start": 95.82933333333334,
      "end": 97.83466666666666,
      "text": "Full markdown syntax support"
    },
    {
      "idx": 28,
      "start": 97.83466666666666,
      "end": 100.224,
      "text": "Code blocks with language highlighting"
    },
    {
      "idx": 29,
      "start": 100.224,
      "end": 102.4,
      "text": "Links, images, and formatting"
    },
    {
      "idx": 30,
      "start": 102.4,
      "end": 104.17066666666666,
      "text": "Lists, tables, and more"
    },
    {
      "idx": 31,
      "start": 104.17066666666666,
      "end": 105.45066666666666,
      "text": "Simple Maintenance"
    },
    {
      "idx": 32,
      "start": 105.45066666666666,
      "end": 108.43733333333333,
      "text": "Version control friendly (just text files)"
    },
    {
      "idx": 33,
      "start": 108.43733333333333,
      "end": 110.44266666666667,
      "text": "Easy to backup and restore"
    },
    {
      "idx": 34,
      "start": 110.44266666666667,
      "end": 113.87733333333334,
      "text": "No database migrations or complex deployments"
    },
    {
      "idx": 35,
      "start": 113.87733333333334,
      "end": 114.92266666666667,
      "text": "File Structure"
    },
    {
      "idx": 36,
      "start": 114.92266666666667,
      "end": 116.672,
      "text": "Benefits of This Approach"
    },
    {
      "idx": 37,
      "start": 116.672,
      "end": 119.59466666666667,
      "text": "Simplicity - Just markdown and JSON"
    },
    {
      "idx": 38,
      "start": 119.59466666666667,
      "end": 122.00533333333334,
      "text": "Performance - Static files load fast"
    },
    {
      "idx": 39,
      "start": 122.00533333333334,
      "end": 125.16266666666667,
      "text": "Reliability - No database dependencies"
    },
    {
      "idx": 40,
      "start": 125.16266666666667,
      "end": 127.72266666666667,
      "text": "Portability - Easy to move or backup"
    },
    {
      "idx": 41,
      "start": 127.72266666666667,
      "end": 130.98666666666668,
      "text": "Version Control - Text files work great with git"
    },
    {
      "idx": 42,
      "start": 130.98666666666668,
      "end": 132.352,
      "text": "Advanced Features"
    },
    {
      "idx": 43,
      "start": 132.352,
      "end": 133.86666666666667,
      "text": "Terminal Integration"
    },
    {
      "idx": 44,
      "start": 133.86666666666667,
      "end": 138.09066666666666,
      "text": "The site features a terminal-style navigation system with commands:"
    },
    {
      "idx": 45,
      "start": 138.09066666666666,
      "end": 140.65066666666667,
      "text": "ls - List articles and directories"
    },
    {
      "idx": 46,
      "start": 140.65066666666667,
      "end": 144.10666666666665,
      "text": "cd articles - Navigate to articles directory"
    },
    {
      "idx": 47,
      "start": 144.10666666666665,
      "end": 147.43466666666666,
      "text": "cat filename.md - Display article content"
    },
    {
      "idx": 48,
      "start": 147.43466666666666,
      "end": 151.40266666666668,
      "text": "tree - Show directory structure with articles sorted by date"
    },
    {
      "idx": 49,
      "start": 151.40266666666668,
      "end": 153.42933333333335,
      "text": "help - Show all available commands"
    },
    {
      "idx": 50,
      "start": 153.42933333333335,
      "end": 155.15733333333333,
      "text": "Dynamic Loading System"
    },
    {
      "idx": 51,
      "start": 155.15733333333333,
      "end": 157.824,
      "text": "The JavaScript implementation includes:"
    },
    {
      "idx": 52,
      "start": 157.824,
      "end": 163.24266666666668,
      "text": "Graceful fallback - If external files fail to load, built-in content is displayed"
    },
    {
      "idx": 53,
      "start": 163.24266666666668,
      "end": 167.78666666666666,
      "text": "Cache busting - Timestamp parameters prevent browser caching issues"
    },
    {
      "idx": 54,
      "start": 167.78666666666666,
      "end": 172.56533333333334,
      "text": "Smooth transitions - Content fades in/out during navigation"
    },
    {
      "idx": 55,
      "start": 172.56533333333334,
      "end": 179.456,
      "text": "Direct linking - URLs like #articles/filename.md work for sharing specific articles"
    },
    {
      "idx": 56,
      "start": 179.456,
      "end": 180.75733333333332,
      "text": "Markdown Parser"
    },
    {
      "idx": 57,
      "start": 180.75733333333332,
      "end": 183.18933333333334,
      "text": "The custom markdown parser handles:"
    },
    {
      "idx": 58,
      "start": 183.18933333333334,
      "end": 185.77066666666667,
      "text": "Headers (H1, H2, H3)"
    },
    {
      "idx": 59,
      "start": 185.77066666666667,
      "end": 188.16,
      "text": "Code blocks with language highlighting"
    },
    {
      "idx": 60,
      "start": 188.16,
      "end": 189.97333333333333,
      "text": "Inline code formatting"
    },
    {
      "idx": 61,
      "start": 189.97333333333333,
      "end": 191.59466666666665,
      "text": "Bold and italic text"
    },
    {
      "idx": 62,
      "start": 191.59466666666665,
      "end": 193.74933333333334,
      "text": "Links with target=\"_blank\""
    },
    {
      "idx": 63,
      "start": 193.74933333333334,
      "end": 195.072,
      "text": "Paragraph wrapping"
    },
    {
      "idx": 64,
      "start": 195.072,
      "end": 197.54666666666665,
      "text": "Preserves formatting within code blocks"
    },
    {
      "idx": 65,
      "start": 197.54666666666665,
      "end": 199.01866666666666,
      "text": "Search Functionality"
    },
    {
      "idx": 66,
      "start": 199.01866666666666,
      "end": 201.19466666666668,
      "text": "When viewing the articles directory:"
    },
    {
      "idx": 67,
      "start": 201.19466666666668,
      "end": 203.98933333333332,
      "text": "Real-time search by title or filename"
    },
    {
      "idx": 68,
      "start": 203.98933333333332,
      "end": 205.78133333333332,
      "text": "Case-insensitive matching"
    },
    {
      "idx": 69,
      "start": 205.78133333333332,
      "end": 208.10666666666665,
      "text": "Instant filtering of article list"
    },
    {
      "idx": 70,
      "start": 208.10666666666665,
      "end": 210.432,
      "text": "Technical Implementation Details"
    },
    {
      "idx": 71,
      "start": 210.432,
      "end": 211.456,
      "text": "Data Flow"
    },
    {
      "idx": 72,
      "start": 211.456,
      "end": 216.256,
      "text": "Page Load: JavaScript fetches articles/articles.json"
    },
    {
      "idx": 73,
      "start": 216.256,
      "end": 221.97333333333333,
      "text": "Article Request: When user clicks an article, JavaScript fetches the .md file"
    },
    {
      "idx": 74,
      "start": 221.97333333333333,
      "end": 226.34666666666666,
      "text": "Parsing: Custom markdown parser converts content to HTML"
    },
    {
      "idx": 75,
      "start": 226.34666666666666,
      "end": 230.08,
      "text": "Display: Content appears with terminal-style navigation"
    },
    {
      "idx": 76,
      "start": 230.08,
      "end": 231.14666666666668,
      "text": "Error Handling"
    },
    {
      "idx": 77,
      "start": 231.14666666666668,
      "end": 235.02933333333334,
      "text": "Network failures: Falls back to built-in article content"
    },
    {
      "idx": 78,
      "start": 235.02933333333334,
      "end": 239.552,
      "text": "Missing files: Shows \"Article Not Found\" message with error details"
    },
    {
      "idx": 79,
      "start": 239.552,
      "end": 243.86133333333333,
      "text": "JSON parse errors: Gracefully handles malformed metadata"
    },
    {
      "idx": 80,
      "start": 243.86133333333333,
      "end": 245.84533333333334,
      "text": "Performance Optimizations"
    },
    {
      "idx": 81,
      "start": 245.84533333333334,
      "end": 249.32266666666666,
      "text": "Lazy loading: Articles only load when requested"
    },
    {
      "idx": 82,
      "start": 249.32266666666666,
      "end": 253.312,
      "text": "Minimal dependencies: No external JavaScript libraries"
    },
    {
      "idx": 83,
      "start": 253.312,
      "end": 257.17333333333335,
      "text": "Efficient caching: Browser caches static files naturally"
    },
    {
      "idx": 84,
      "start": 257.17333333333335,
      "end": 262.61333333333334,
      "text": "Small footprint: Entire site is a single HTML file + articles"
    },
    {
      "idx": 85,
      "start": 262.61333333333334,
      "end": 264.448,
      "text": "File Naming Conventions"
    },
    {
      "idx": 86,
      "start": 264.448,
      "end": 267.456,
      "text": "Use lowercase with hyphens for readability:"
    },
    {
      "idx": 87,
      "start": 267.456,
      "end": 270.784,
      "text": "\u2705 my-article-title.md"
    },
    {
      "idx": 88,
      "start": 270.784,
      "end": 274.048,
      "text": "\u2705 linux-tutorial.md"
    },
    {
      "idx": 89,
      "start": 274.048,
      "end": 276.736,
      "text": "\u274c MyArticleTitle.md"
    },
    {
      "idx": 90,
      "start": 276.736,
      "end": 279.424,
      "text": "\u274c my_article_title.md"
    },
    {
      "idx": 91,
      "start": 279.424,
      "end": 280.2986666666667,
      "text": "Deployment"
    },
    {
      "idx": 92,
      "start": 280.2986666666667,
      "end": 282.56,
      "text": "The deployment is equally simple:"
    },
    {
      "idx": 93,
      "start": 282.56,
      "end": 292.224,
      "text": "This rsync script pushes all changes to the production server, excluding .git/, archive/, and .well-known/ directories."
    },
    {
      "idx": 94,
      "start": 292.224,
      "end": 307.8826666666667,
      "text": "This system proves that you don't need complex tools to create a beautiful, functional website. Sometimes the simplest solution is the best solution - and this custom article system exemplifies the philosophy of parsimony in web development."
    }
  ]
}
