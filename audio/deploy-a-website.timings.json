    },
    {
      "idx": 89,
      "start": 325.20533333333333,
      "end": 327.50933333333336,
      "text": "Verify nginx is running:"
    },
    {
      "idx": 90,
      "start": 327.50933333333336,
      "end": 329.77066666666667,
      "text": "Check nginx configuration:"
    },
    {
      "idx": 91,
      "start": 329.77066666666667,
      "end": 331.8826666666667,
      "text": "Review nginx error logs:"
    },
    {
      "idx": 92,
      "start": 331.8826666666667,
      "end": 333.8453333333333,
      "text": "SSL Certificate Issues"
    },
    {
      "idx": 93,
      "start": 333.8453333333333,
      "end": 337.4293333333333,
      "text": "Ensure domain points to server before running certbot"
    },
    {
      "idx": 94,
      "start": 337.4293333333333,
      "end": 341.97333333333336,
      "text": "Check firewall allows HTTP/HTTPS traffic"
    },
    {
      "idx": 95,
      "start": 341.97333333333336,
      "end": 345.152,
      "text": "Verify nginx configuration is correct"
    },
    {
      "idx": 96,
