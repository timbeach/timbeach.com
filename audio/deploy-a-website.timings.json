      "end": 136.768,
      "text": "Step 4: Firewall Configuration"
    },
    {
      "idx": 37,
      "start": 136.768,
      "end": 140.224,
      "text": "Configure UFW (Uncomplicated Firewall)"
    },
    {
      "idx": 38,
      "start": 140.224,
      "end": 144.704,
      "text": "Step 5: SSL Certificate Setup (Optional but Recommended)"
    },
    {
      "idx": 39,
      "start": 144.704,
      "end": 147.73333333333332,
      "text": "Install Certbot for Let's Encrypt SSL"
    },
    {
      "idx": 40,
      "start": 147.73333333333332,
      "end": 150.03733333333332,
      "text": "Important Prerequisites for Certbot:"
    },
    {
      "idx": 41,
      "start": 150.03733333333332,
      "end": 156.224,
      "text": "DNS must be working: Your domain must already be pointing to your server and resolving correctly"
    },
    {
      "idx": 42,
      "start": 156.224,
      "end": 163.41333333333333,
      "text": "HTTP must be accessible: Your nginx site must be working on port 80 before running certbot"
    },
    {
      "idx": 43,
      "start": 163.41333333333333,
      "end": 171.60533333333333,
      "text": "Firewall must allow HTTP/HTTPS: Ensure ports 80 and 443 are open"
    },
    {
      "idx": 44,
      "start": 171.60533333333333,
      "end": 172.94933333333333,
      "text": "How Certbot Works:"
    },
    {
      "idx": 45,
      "start": 172.94933333333333,
      "end": 178.368,
      "text": "Certbot creates temporary files in your web directory to verify domain ownership"
    },
    {
      "idx": 46,
      "start": 178.368,
      "end": 184.64,
      "text": "Let's Encrypt servers access these files via HTTP to confirm you control the domain"
    },
    {
      "idx": 47,
      "start": 184.64,
      "end": 188.62933333333334,
      "text": "Once verified, certbot downloads the SSL certificates"
    },
    {
      "idx": 48,
      "start": 188.62933333333334,
      "end": 194.112,
      "text": "The  flag automatically updates your nginx configuration to use HTTPS"
    },
    {
      "idx": 49,
      "start": 194.112,
      "end": 198.12266666666667,
      "text": "Certbot sets up automatic renewal via systemd timer"
    },
    {
      "idx": 50,
      "start": 198.12266666666667,
      "end": 199.44533333333334,
      "text": "If Certbot Fails:"
    },
    {
      "idx": 51,
      "start": 199.44533333333334,
      "end": 203.49866666666668,
      "text": "Verify domain resolution:  should return your server IP"
    },
    {
      "idx": 52,
      "start": 203.49866666666668,
      "end": 208.064,
      "text": "Test HTTP access:  should return a 200 response"
    },
    {
      "idx": 53,
      "start": 208.064,
      "end": 209.81333333333333,
      "text": "Check nginx logs:"
    },
    {
      "idx": 54,
      "start": 209.81333333333333,
      "end": 212.992,
      "text": "Ensure no other services are using port 80"
    },
    {
      "idx": 55,
      "start": 212.992,
      "end": 214.67733333333334,
      "text": "This will automatically:"
    },
    {
      "idx": 56,
      "start": 214.67733333333334,
      "end": 217.70666666666668,
      "text": "Obtain SSL certificates from Let's Encrypt"
    },
    {
      "idx": 57,
      "start": 217.70666666666668,
      "end": 225.216,
      "text": "Update nginx configuration to use HTTPS and redirect HTTP to HTTPS"
    },
    {
      "idx": 58,
      "start": 225.216,
      "end": 230.35733333333334,
      "text": "Set up automatic certificate renewal (certificates expire every 90 days)"
    },
    {
      "idx": 59,
      "start": 230.35733333333334,
      "end": 232.96,
      "text": "Step 6: Verification and Testing"
    },
    {
      "idx": 60,
      "start": 232.96,
      "end": 235.072,
      "text": "Test Website Accessibility"
    },
    {
      "idx": 61,
      "start": 235.072,
      "end": 239.70133333333334,
      "text": "DNS Propagation: Use tools like  or online DNS checkers"
    },
    {
      "idx": 62,
      "start": 239.70133333333334,
      "end": 244.33066666666667,
      "text": "DNS Propagation: Use tools like  or online DNS checkers"
    },
    {
      "idx": 63,
      "start": 244.33066666666667,
      "end": 247.232,
      "text": "HTTP Response: Test with curl"
    },
    {
      "idx": 64,
