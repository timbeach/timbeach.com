    },
    {
      "idx": 33,
      "start": 128.27733333333333,
      "end": 131.09333333333333,
      "text": "Create nginx configuration file:"
    },
    {
      "idx": 34,
      "start": 131.09333333333333,
      "end": 133.248,
      "text": "Add the following configuration:"
    },
    {
      "idx": 35,
