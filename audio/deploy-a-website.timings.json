    },
    {
      "idx": 86,
      "start": 315.34933333333333,
      "end": 321.3226666666667,
      "text": "Wait for DNS propagation (up to 48 hours) but it usually only takes a few minutes"
    },
    {
      "idx": 87,
      "start": 321.3226666666667,
      "end": 323.6906666666667,
      "text": "Use DNS checker tools online"
    },
    {
