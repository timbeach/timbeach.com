      "text": "System Updates:"
    },
    {
      "idx": 74,
      "start": 278.4,
      "end": 281.408,
      "text": "Log Monitoring: Check nginx logs in"
    },
    {
      "idx": 75,
      "start": 281.408,
      "end": 286.272,
      "text": "SSL Renewal: Automated via certbot, but monitor for issues"
    },
    {
      "idx": 76,
      "start": 286.272,
      "end": 290.83733333333333,
      "text": "Backup: Regular backups of website files and server configuration"
    },
    {
      "idx": 77,
      "start": 290.83733333333333,
      "end": 291.6906666666667,
      "text": "Monitoring"
    },
    {
      "idx": 78,
      "start": 291.6906666666667,
      "end": 292.928,
      "text": "Cost Breakdown"
    },
    {
      "idx": 79,
      "start": 292.928,
